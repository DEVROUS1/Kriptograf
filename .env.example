# ── Veritabanı ───────────────────────────────────────────────────────────────
POSTGRES_USER=kriptograf
POSTGRES_PASSWORD=BURAYA_EN_AZ_20_KARAKTERLI_SIFRE
POSTGRES_DB=kriptograf_db

# ── Redis (Upstash önerilir) ──────────────────────────────────────────────────
REDIS_PASSWORD=BURAYA_REDIS_SIFRESI
# Upstash kullanıyorsanız tam URL:
# REDIS_URL=rediss://:sifre@xxx.upstash.io:6379

# ── Uygulama ──────────────────────────────────────────────────────────────────
# python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=BURAYA_64_KARAKTERLI_RASTGELE_KEY
DEBUG=false
LOG_LEVEL=info

# ── AI (Groq) ─────────────────────────────────────────────────────────────────
# console.groq.com > API Keys > Create
GROQ_API_KEY=gsk_...

# ── CORS ─────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=https://kriptograf.pages.dev

# ── Frontend Build ────────────────────────────────────────────────────────────
